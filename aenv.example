# =============================================
# AFIP / ARCA - Web Services
# =============================================
# Documentación oficial: https://www.afip.gob.ar/ws/documentacion/wsaa.asp
#
# Proceso para obtener el certificado:
# 1. Generar clave privada y CSR:
#    openssl genrsa -out certs/private.key 2048
#    openssl req -new -key certs/private.key -out certs/certificate.csr \
#      -subj "/C=AR/O=MI EMPRESA SA/serialNumber=CUIT 30XXXXXXXXX/CN=REMITERO-AFIP"
# 2. Para testing: subir certs/certificate.csr al WSASS en:
#    https://wsass-homo.afip.gov.ar/wsass/portal.htm
#    (requiere adherirse al WSASS vía Administrador de Relaciones de Clave Fiscal)
# 3. Para producción: subir el CSR en "Administración de Certificados Digitales" del portal AFIP
# 4. Descargar el .crt resultante y guardarlo como certs/cert.crt
# 5. Asociar el certificado al servicio WSFEv1 en AFIP (comprobante tipo 91 = Remito R)

# CUIT de la empresa emisora (sin guiones, 11 dígitos); debe coincidir con el certificado ARCA
AFIP_CUIT=30693787285

# Rutas a los archivos de certificado (generados con OpenSSL + portal AFIP)
AFIP_CERT_PATH=./certs/cert.crt
AFIP_KEY_PATH=./certs/private.key

# Ambiente: false = homologación/testing, true = producción real
AFIP_PRODUCTION=false

# Número de punto de venta habilitado en AFIP para este sistema
# Configurar en: portal AFIP > Mis Datos > Puntos de Venta
AFIP_PUNTO_VENTA=1

# =============================================
# Base de datos
# =============================================

# URI de conexión a MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/remitero?retryWrites=true&w=majority
